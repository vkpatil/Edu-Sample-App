    },
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', parameters('vnetName'), parameters('appsSubnetName'))]",
      "properties": {
        "addressPrefix": "[parameters('appsSubnetPrefix')]",
        "networkSecurityGroup": {
