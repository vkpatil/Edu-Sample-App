# Django Configuration
DEBUG=1
SECRET_KEY=django-insecure-replace-this-in-real-env
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database Configuration
POSTGRES_DB=edusys
POSTGRES_USER=edusys
POSTGRES_PASSWORD=edusys
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email Configuration
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USE_TLS=0
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=no-reply@edusys.local

# Azure Key Vault Configuration
# For local development, disable Key Vault and use environment variables instead
DISABLE_KEY_VAULT=1

# For production with Azure Key Vault, set the vault URL:
# AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
# Make sure the app's managed identity has access to the vault
